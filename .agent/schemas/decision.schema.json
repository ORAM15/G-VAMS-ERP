{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://g-vams.local/agent/decision.schema.json",
  "title": "G-VAMS Autonomous Agent Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cycle_id",
    "selected_backlog_id",
    "selected_improvement",
    "selection_reason",
    "declared_scope",
    "allowed_paths",
    "forbidden_paths",
    "planned_validation",
    "risk_level"
  ],
  "properties": {
    "cycle_id": { "type": "string", "minLength": 3, "pattern": "^[A-Za-z0-9._:-]+$" },
    "selected_backlog_id": { "type": ["string", "null"] },
    "selected_improvement": { "type": "string", "minLength": 1 },
    "selection_reason": { "type": "string", "minLength": 1 },
    "declared_scope": { "type": "string", "minLength": 1 },
    "allowed_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "forbidden_paths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "planned_validation": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "repository_observed_improvement": { "type": "string" }
  },
  "anyOf": [
    { "properties": { "selected_backlog_id": { "type": "string", "minLength": 1 } }, "required": ["selected_backlog_id"] },
    { "properties": { "repository_observed_improvement": { "type": "string", "minLength": 1 } }, "required": ["repository_observed_improvement"] }
  ]
}
